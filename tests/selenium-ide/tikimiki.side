    },
    {
      "id": "t0000000-0000-4000-8000-000000000006",
      "name": "Kanban - otvaranje table",
      "commands": [
        { "id": "c601", "comment": "IDE-KAN-01: preduslov prijava (clan u timu)", "command": "run", "target": "Prijava - clan (uspesna)", "targets": [], "value": "" },
        { "id": "c602", "comment": "Otvori timove", "command": "open", "target": "/teams", "targets": [], "value": "" },
        { "id": "c603", "comment": "Link ka kanban tabli tima", "command": "waitForElementPresent", "target": "css=a[href*='/kanban']", "targets": [], "value": "10000" },
        { "id": "c604", "comment": "Otvori kanban tablu", "command": "click", "target": "css=a[href*='/kanban']", "targets": [], "value": "" },
        { "id": "c605", "comment": "Dugme za dodavanje kartice postoji => tabla je ucitana", "command": "waitForElementVisible", "target": "css=.kb-add-card-btn", "targets": [], "value": "10000" },
