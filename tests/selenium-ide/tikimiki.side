        { "id": "c503", "comment": "Polje za naziv mora biti vidljivo", "command": "waitForElementVisible", "target": "id=nh-title", "targets": [], "value": "15000" },
        { "id": "c504", "comment": "Unesi naziv", "command": "type", "target": "id=nh-title", "targets": [], "value": "Hakaton iz Selenium IDE" },
        { "id": "c505", "comment": "Polje za opis prisutno", "command": "assertElementPresent", "target": "id=nh-desc", "targets": [], "value": "" }
