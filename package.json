{
  "name": "tikimiki",
  "version": "0.1.0",
  "private": true,
  "description": "tikimiki — all-in-one hackathon platform (monorepo)",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "pnpm --parallel --filter ./frontend --filter ./backend dev",
    "dev:web": "pnpm --filter ./frontend dev",
    "dev:api": "pnpm --filter ./backend start:dev",
    "start:all": "pnpm db:up && pnpm dev",
    "db:setup": "pnpm db:up && pnpm db:migrate && pnpm db:seed",
    "db:seed": "pnpm --filter ./backend db:seed",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "bash scripts/format.sh --write",
    "format:check": "bash scripts/format.sh --check",
    "typecheck": "pnpm --filter ./backend typecheck && pnpm --filter ./frontend exec tsc --noEmit",
    "check": "pnpm format:check -a && pnpm lint && pnpm typecheck && pnpm test:unit",
    "prepare": "husky",
    "test": "pnpm -r test",
    "test:unit": "pnpm --filter ./backend test:unit",
    "test:ui": "cd tests/selenium-webdriver && npm test",
    "db:up": "docker compose up -d postgres redis",
    "db:down": "docker compose down",
    "db:generate": "pnpm --filter ./backend db:generate",
    "db:migrate": "pnpm --filter ./backend db:migrate"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,css,md,yml,yaml}": "prettier --write"
  }
}
