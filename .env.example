# Copy to .env and adjust. Used by docker-compose and the backend.

# --- PostgreSQL ---
POSTGRES_USER=tikimiki
POSTGRES_PASSWORD=tikimiki
POSTGRES_DB=tikimiki
POSTGRES_PORT=5432

# --- Redis ---
REDIS_PORT=6379

# --- Backend (NestJS) ---
# Full connection string Drizzle / NestJS use:
DATABASE_URL=postgres://tikimiki:tikimiki@localhost:5432/tikimiki
REDIS_URL=redis://localhost:6379
PORT=4000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=change-me-access
JWT_REFRESH_SECRET=change-me-refresh
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=2592000

# OAuth (GitHub / Google) — leave blank to keep social login disabled.
# Register an OAuth app with each provider and set the callback URL to
#   <OAUTH_REDIRECT_BASE>/api/v1/auth/oauth/<github|google>/callback
# OAUTH_REDIRECT_BASE is the origin the BROWSER uses (the Next dev server,
# which proxies /api/v1 and /uploads to the backend).
OAUTH_REDIRECT_BASE=http://localhost:3000
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
